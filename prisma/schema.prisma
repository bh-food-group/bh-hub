generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["audit", "cost", "dashboard", "delivery", "inventory", "labor", "order", "public"]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("public")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("public")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
  @@schema("public")
}

model Realm {
  id               String     @id @default(cuid())
  realmId          String     @unique @map("realm_id")
  name             String
  accessToken      String?    @map("access_token")
  refreshToken     String?    @map("refresh_token")
  expiresAt        DateTime?  @map("expires_at")
  refreshExpiresAt DateTime?  @map("refresh_expires_at")
  createdAt        DateTime   @default(now()) @map("created_at")
  locations        Location[]

  @@map("realms")
  @@schema("public")
}

model Location {
  id                       String                  @id @default(cuid())
  code                     String                  @unique
  name                     String
  createdAt                DateTime                @default(now()) @map("created_at")
  classId                  String?                 @map("class_id")
  realmId                  String                  @map("realm_id")
  startYearMonth           String?                 @map("start_year_month")
  showBudget               Boolean                 @default(true) @map("show_budget")
  cloverMerchantId         String?                 @map("clover_merchant_id")
  cloverToken              String?                 @map("clover_token")
  /// Representative customer email used to place Shopify orders for this location.
  /// Location order page filters orders by this, regardless of the viewer's login email.
  orderEmail               String?                 @map("order_email")
  budgets                  Budget[]
  laborTargets             LaborTarget[]
  revenueAnnualGoals       RevenueAnnualGoal[]
  revenueMonthTargets      RevenueMonthTarget[]
  cloverWeeklyCaches       CloverWeeklyCache[]
  laborSettings            LaborSettings?
  cloverSalesHourly        CloverSalesHourly[]
  salesHeatmapCache        SalesHeatmapCache[]
  salesSampleExclusions    SalesSampleExclusion[]
  revenueForecasts         RevenueForecast[]
  fixedPayrolls            FixedPayroll[]
  laborPlans               LaborPlan[]
  realm                    Realm                   @relation(fields: [realmId], references: [id])
  users                    User[]
  /// Optional default ship-to preset shared with other locations (many `Location`s may point to the same preset).
  deliveryLocationPresetId String?                 @map("delivery_location_preset_id")
  deliveryLocationPreset   DeliveryLocationPreset? @relation(fields: [deliveryLocationPresetId], references: [id], onDelete: SetNull)

  @@index([deliveryLocationPresetId])
  @@map("locations")
  @@schema("public")
}

/// Office + delivery: reusable ship-to address. Many `Location` rows may reference the same preset via `locations.delivery_location_preset_id`.
model DeliveryLocationPreset {
  id         String   @id @default(cuid())
  /// Short label for search (e.g. “Loading dock”, “Catering kitchen”).
  name       String
  company    String?
  address1   String   @map("address1")
  address2   String?  @map("address2")
  city       String
  province   String
  postalCode String   @map("postal_code")
  country    String   @default("CA")
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  locations      Location[]
  purchaseOrders PurchaseOrder[]

  @@map("delivery_location_presets")
  @@schema("public")
}

model User {
  id                       String                    @id @default(cuid())
  name                     String?
  email                    String?                   @unique
  emailVerified            DateTime?                 @map("email_verified")
  image                    String?
  role                     UserRole?                 @default(manager)
  status                   UserStatus                @default(pending_onboarding) @map("status")
  locationId               String?                   @map("location_id")
  permittedById            String?                   @map("permitted_by_id")
  permittedAt              DateTime?                 @map("permitted_at")
  createdAt                DateTime                  @default(now()) @map("created_at")
  updatedAt                DateTime                  @updatedAt @map("updated_at")
  rejectReason             String?                   @map("reject_reason")
  budgetSettings           BudgetSettings[]          @relation("BudgetSettingsUpdatedBy")
  costEditHistory          CostEditHistory[]
  costMemos                CostMemo[]
  accounts                 Account[]
  sessions                 Session[]
  location                 Location?                 @relation(fields: [locationId], references: [id])
  permittedBy              User?                     @relation("UserPermittedBy", fields: [permittedById], references: [id])
  permittedUsers           User[]                    @relation("UserPermittedBy")
  /// delivery.Driver.userId → public.users.id (one driver profile per user)
  driver                   Driver?
  /// `order.purchase_orders.created_by_id` — POs created in the hub (not legacy CSV id).
  purchaseOrdersCreated    PurchaseOrder[]           @relation("PurchaseOrderCreatedBy")
  /// `order.refund_replacement_records.created_by_id`
  refundReplacementRecords RefundReplacementRecord[] @relation("RefundReplacementCreatedBy")

  @@map("users")
  @@schema("public")
}

enum UserRole {
  admin
  office
  manager
  supply
  employee
  supplier

  @@schema("public")
}

enum UserStatus {
  pending_onboarding
  pending_approval
  active
  rejected

  @@schema("public")
}

// ===============================
// DASHBOARD (budget + labor targets)
// ===============================
model BudgetSettings {
  id                    String   @id @default(cuid())
  budgetRate            Decimal  @map("budget_rate") @db.Decimal(5, 4)
  referencePeriodMonths Int      @map("reference_period_months")
  updatedAt             DateTime @updatedAt @map("updated_at")
  updatedById           String?  @map("updated_by_id")
  updatedBy             User?    @relation("BudgetSettingsUpdatedBy", fields: [updatedById], references: [id])

  @@map("budget_settings")
  @@schema("dashboard")
}

model Budget {
  id                        String   @id @default(cuid())
  locationId                String   @map("location_id")
  yearMonth                 String   @map("year_month")
  totalAmount               Decimal  @map("total_amount") @db.Decimal(14, 2)
  createdAt                 DateTime @default(now()) @map("created_at")
  budgetRateUsed            Decimal? @map("budget_rate_used") @db.Decimal(5, 4)
  referencePeriodMonthsUsed Int?     @map("reference_period_months_used")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  error                     String?  @map("error")
  location                  Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, yearMonth])
  @@map("budgets")
  @@schema("dashboard")
}

/**
 * Labor dashboard target (rate × ref income ÷ months). Independent of Cost budget.
 */
model LaborTarget {
  id                    String   @id @default(cuid())
  locationId            String   @map("location_id")
  yearMonth             String   @map("year_month")
  rate                  Decimal  @map("rate") @db.Decimal(5, 4)
  referencePeriodMonths Int      @map("reference_period_months")
  updatedAt             DateTime @updatedAt @map("updated_at")
  location              Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, yearMonth])
  @@map("labor_targets")
  @@schema("dashboard")
}

/// Calendar-year revenue goal per location (can change year over year).
model RevenueAnnualGoal {
  id           String   @id @default(cuid())
  locationId   String   @map("location_id")
  calendarYear Int      @map("calendar_year")
  goalAmount   Decimal  @map("goal_amount") @db.Decimal(14, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, calendarYear])
  @@map("revenue_annual_goals")
  @@schema("dashboard")
}

/**
 * Clover weekday/holiday mix for a specific dashboard month (YYYY-MM).
 * `referencePeriodMonths` = full calendar months before `appliesYearMonth` (excluded) for Clover lookback; 0 = no mix / no targets from this row.
 * `refYearMonth` kept for legacy rows; new writes mirror `appliesYearMonth`.
 */
model RevenueMonthTarget {
  id                    String   @id @default(cuid())
  locationId            String   @map("location_id")
  appliesYearMonth      String   @map("applies_year_month")
  referencePeriodMonths Int      @default(12) @map("reference_period_months")
  sharesJson            String   @map("shares_json") @db.Text
  computedAt            DateTime @map("computed_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  location              Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, appliesYearMonth])
  @@map("revenue_month_targets")
  @@schema("dashboard")
}

/// Clover weekly revenue response cache. Past weeks (weekEndDate < today) are immutable; cached indefinitely.
model CloverWeeklyCache {
  id            String   @id @default(cuid())
  locationId    String   @map("location_id")
  weekStartDate String   @map("week_start_date")
  weekEndDate   String   @map("week_end_date")
  dataJson      String   @map("data_json") @db.Text
  cachedAt      DateTime @map("cached_at")
  location      Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, weekStartDate])
  @@map("clover_weekly_cache")
  @@schema("dashboard")
}

// ===============================
// COST (from bh-cost-analysis; no Organization)
// ===============================
model Cost {
  id               String            @id @default(cuid())
  title            String
  totalCount       Int
  lossAmount       Float?
  finalWeight      Float?
  locked           Boolean           @default(false)
  ingredients      Ingredient[]
  packagings       Packaging[]
  labors           Labor[]
  others           Other[]
  prices           Price[]
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  CostEditHistory  CostEditHistory[]
  costMemos        CostMemo[]
  costTagRelations CostTagRelation[]

  @@map("costs")
  @@schema("cost")
}

model Ingredient {
  id        String   @id @default(cuid())
  title     String
  unit      String
  amount    Float
  costId    String
  variantId String
  type      String   @default("")
  image     Json?
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("ingredients")
  @@schema("cost")
}

model Packaging {
  id        String   @id @default(cuid())
  title     String
  unit      String
  amount    Float
  costId    String
  variantId String
  type      String   @default("")
  image     Json?
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("packagings")
  @@schema("cost")
}

model Labor {
  id        String   @id @default(cuid())
  title     String
  time      Float
  people    Int
  wage      Float
  costId    String
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("labors")
  @@schema("cost")
}

model Other {
  id        String   @id @default(cuid())
  title     String
  amount    Float
  costId    String
  rank      String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("others")
  @@schema("cost")
}

model Price {
  id           String   @id @default(cuid())
  title        String
  margin       Float
  price        Float
  costId       String
  base         String?
  rank         String
  isFinalPrice Boolean  @default(false)
  Cost         Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now()) @db.Timestamptz
  updatedAt    DateTime @updatedAt @db.Timestamptz

  @@map("prices")
  @@schema("cost")
}

model Tag {
  id               String            @id @default(cuid())
  name             String
  color            String            @default("gray")
  createdAt        DateTime          @default(now()) @db.Timestamptz
  updatedAt        DateTime          @updatedAt @db.Timestamptz
  costTagRelations CostTagRelation[]

  @@map("tags")
  @@schema("cost")
}

model CostTagRelation {
  costId String
  tagId  String
  Cost   Cost   @relation(fields: [costId], references: [id], onDelete: Cascade)
  Tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([costId, tagId])
  @@map("cost_tags")
  @@schema("cost")
}

model CostEditHistory {
  id        String   @id @default(cuid())
  costId    String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction)
  log       Json
  createdAt DateTime @default(now()) @db.Timestamptz

  @@map("cost_edit_history")
  @@schema("cost")
}

model CostMemo {
  id        String   @id @default(cuid())
  costId    String
  Cost      Cost     @relation(fields: [costId], references: [id], onDelete: Cascade)
  userId    String
  User      User     @relation(fields: [userId], references: [id], onDelete: NoAction)
  memo      String
  rank      String
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("cost_memos")
  @@schema("cost")
}

model ShopifyConfig {
  id                 String   @id @default(cuid())
  shopifyUrl         String
  adminToken         String
  apiVersion         String
  query              String?
  costFieldConfig    Json[]
  productFieldConfig Json[]
  createdAt          DateTime @default(now()) @db.Timestamptz
  updatedAt          DateTime @updatedAt @db.Timestamptz

  @@map("shopify_config")
  @@schema("cost")
}

model PriceConfig {
  id            String   @id @default(cuid())
  defaultPrices Json[]
  createdAt     DateTime @default(now()) @db.Timestamptz
  updatedAt     DateTime @updatedAt @db.Timestamptz

  @@map("price_config")
  @@schema("cost")
}

// ===============================
// DELIVERY (driver scheduling)
// DeliveryLocation: main locations for everyday schedule (can reference public Location).
// Occasional locations for one-time events are stored inline in DailyScheduleStop (name/address/lat/lng).
// ===============================
model DeliveryLocation {
  id         String   @id @default(cuid())
  name       String
  address    String?
  lat        Float?
  lng        Float?
  locationId String?  @map("location_id") // optional FK to public.Location for future 물류/재고
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  dailyStops DailyScheduleStop[]
  fixedStops FixedScheduleStop[]

  @@map("delivery_locations")
  @@schema("delivery")
}

model Driver {
  id                      String    @id @default(cuid())
  userId                  String    @unique @map("user_id") // User (public) who is this driver
  /// Set when office requests a fresh GPS fix; cleared when the driver app POSTs location.
  locationPingRequestedAt DateTime? @map("location_ping_requested_at") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  fixedSchedules  DriverFixedSchedule[]
  dailyStops      DailyScheduleStop[]
  locationUpdates DriverLocationUpdate[]

  @@map("drivers")
  @@schema("delivery")
}

// Day of week: 0=Sunday, 1=Monday, ..., 6=Saturday. Recurring: e.g. TUE=3, THU=5.
// Template stops/tasks define the recurring schedule; when the date comes, daily schedule is created from this template.
model DriverFixedSchedule {
  id        String   @id @default(cuid())
  driverId  String   @map("driver_id")
  dayOfWeek Int      @map("day_of_week") // 0-6
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  driver        Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  templateStops FixedScheduleStop[]

  @@unique([driverId, dayOfWeek])
  @@map("driver_fixed_schedules")
  @@schema("delivery")
}

// Template stop for a recurring weekday (same shape as DailyScheduleStop for copy-to-daily).
model FixedScheduleStop {
  id                 String   @id @default(cuid())
  fixedScheduleId    String   @map("fixed_schedule_id")
  sequence           Int      @map("sequence")
  deliveryLocationId String?  @map("delivery_location_id")
  name               String   @map("name")
  address            String?  @map("address")
  lat                Float?   @map("lat")
  lng                Float?   @map("lng")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz

  fixedSchedule    DriverFixedSchedule @relation(fields: [fixedScheduleId], references: [id], onDelete: Cascade)
  deliveryLocation DeliveryLocation?   @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)
  tasks            FixedScheduleTask[]

  @@map("fixed_schedule_stops")
  @@schema("delivery")
}

model FixedScheduleTask {
  id                  String   @id @default(cuid())
  fixedScheduleStopId String   @map("fixed_schedule_stop_id")
  title               String   @map("title")
  sequence            Int      @map("sequence")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  fixedScheduleStop FixedScheduleStop @relation(fields: [fixedScheduleStopId], references: [id], onDelete: Cascade)

  @@map("fixed_schedule_tasks")
  @@schema("delivery")
}

// Daily stops are keyed by date + driver; no separate Schedule table. Query by date (and driverId) to get a "schedule".
model DailyScheduleStop {
  id                 String    @id @default(cuid())
  date               DateTime  @db.Date
  driverId           String    @map("driver_id")
  sequence           Int       @map("sequence")
  deliveryLocationId String?   @map("delivery_location_id")
  name               String    @map("name") // from location or occasional
  address            String?   @map("address")
  lat                Float?    @map("lat")
  lng                Float?    @map("lng")
  arrivedAt          DateTime? @map("arrived_at") @db.Timestamptz
  departedAt         DateTime? @map("departed_at") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz

  driver           Driver              @relation(fields: [driverId], references: [id], onDelete: Cascade)
  deliveryLocation DeliveryLocation?   @relation(fields: [deliveryLocationId], references: [id], onDelete: SetNull)
  tasks            DailyScheduleTask[]

  @@index([date, driverId])
  @@map("daily_schedule_stops")
  @@schema("delivery")
}

model DailyScheduleTask {
  id                  String    @id @default(cuid())
  dailyScheduleStopId String    @map("daily_schedule_stop_id")
  title               String    @map("title")
  sequence            Int       @map("sequence")
  assignedById        String?   @map("assigned_by_id")
  assignedAt          DateTime? @map("assigned_at") @db.Timestamptz
  completedAt         DateTime? @map("completed_at") @db.Timestamptz
  isDismissed         Boolean   @default(false) @map("is_dismissed")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  dailyScheduleStop DailyScheduleStop @relation(fields: [dailyScheduleStopId], references: [id], onDelete: Cascade)

  @@map("daily_schedule_tasks")
  @@schema("delivery")
}

// GPS updates from driver app for office to see current location and today's route (이동경로)
model DriverLocationUpdate {
  id        String   @id @default(cuid())
  driverId  String   @map("driver_id")
  lat       Float    @map("lat")
  lng       Float    @map("lng")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, createdAt])
  @@map("driver_location_updates")
  @@schema("delivery")
}

// ===============================
// ORDER (Shopify-first order management)
// ===============================

// --- Shopify synced data (source of truth for customers, orders, fulfillment) ---

model ShopifyCustomer {
  id                    String         @id @default(cuid())
  shopifyGid            String         @unique @map("shopify_gid")
  displayName           String?        @map("display_name")
  /// Local override for display name (not synced back to Shopify).
  displayNameOverride   String?        @map("display_name_override")
  email                 String?
  phone                 String?
  company               String?
  /// Short code for default PO numbers (e.g. `6107 MA - …`); not synced to Shopify.
  officePoAccountCode   String?        @map("office_po_account_code")
  /// Default shipping address (JSON: address1, address2, city, province, postalCode, country).
  shippingAddress       Json?          @map("shipping_address")
  /// Default billing address (JSON, same shape as shipping).
  billingAddress        Json?          @map("billing_address")
  billingSameAsShipping Boolean        @default(true) @map("billing_same_as_shipping")
  syncedAt              DateTime       @default(now()) @map("synced_at") @db.Timestamptz
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  orders                ShopifyOrder[]
  fulfillments          Fulfillment[]
  supplierDeliverySchedules SupplierCustomerDeliverySchedule[]
  presetScheduleExceptions  DeliverySchedulePresetCustomerException[]

  @@index([email])
  @@map("shopify_customers")
  @@schema("order")
}

model ShopifyOrder {
  id                       String                 @id @default(cuid())
  shopifyGid               String                 @unique @map("shopify_gid")
  /// Display name as shown in Shopify (e.g. "#5902").
  name                     String
  /// Numeric portion of the order name for fast lookups.
  orderNumber              Int                    @map("order_number")
  customerId               String?                @map("customer_id")
  customer                 ShopifyCustomer?       @relation(fields: [customerId], references: [id])
  email                    String?
  displayFulfillmentStatus String?                @map("display_fulfillment_status")
  displayFinancialStatus   String?                @map("display_financial_status")
  currencyCode             String?                @map("currency_code")
  totalPrice               Decimal?               @map("total_price") @db.Decimal(14, 2)
  processedAt              DateTime?              @map("processed_at") @db.Timestamptz
  shopifyCreatedAt         DateTime?              @map("shopify_created_at") @db.Timestamptz
  billingAddress           Json?                  @map("billing_address")
  shippingAddress          Json?                  @map("shipping_address")
  /// Customer-visible order note from Shopify (`Order.note`).
  customerNote             String?                @map("customer_note") @db.Text
  archivedAt               DateTime?              @map("archived_at") @db.Timestamptz
  /// Office inbox: mark order “on hold” until cleared (not synced to Shopify).
  officePendingAt          DateTime?              @map("office_pending_at") @db.Timestamptz
  syncedAt                 DateTime               @default(now()) @map("synced_at") @db.Timestamptz
  /// True for internally-created replacement orders (missing/damaged items); not synced from Shopify.
  isReplacementOrder       Boolean                @default(false) @map("is_custom_order")
  /// Display-only Shopify order names this replacement order was created from (e.g. "#5902, #5903"). Null for real Shopify orders.
  referenceOrderNames      String?                @map("reference_order_names") @db.Text
  /// The PO that spawned this replacement order. Null for real Shopify orders.
  sourcePurchaseOrderId    String?                @map("source_purchase_order_id")
  createdAt                DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime               @updatedAt @map("updated_at") @db.Timestamptz
  lineItems                ShopifyOrderLineItem[]
  purchaseOrders           PurchaseOrder[]
  fulfillments             Fulfillment[]

  @@index([orderNumber])
  @@index([customerId])
  @@index([displayFulfillmentStatus])
  @@index([isReplacementOrder])
  @@map("shopify_orders")
  @@schema("order")
}

model ShopifyOrderLineItem {
  id                            String                  @id @default(cuid())
  shopifyGid                    String                  @unique @map("shopify_gid")
  orderId                       String                  @map("order_id")
  order                         ShopifyOrder            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  title                         String?
  sku                           String?
  variantTitle                  String?                 @map("variant_title")
  /// Shopify `Product` GID when known (variant’s product or line-level product) — Admin product URLs.
  productGid                    String?                 @map("product_gid")
  variantGid                    String?                 @map("variant_gid")
  /// Product/variant image URL from Shopify (line, variant, or product featured image).
  imageUrl                      String?                 @map("image_url") @db.Text
  /// Shopify product vendor name at order creation time (frozen snapshot).
  vendor                        String?
  quantity                      Int                     @default(0)
  price                         Decimal?                @db.Decimal(14, 2)
  /// Variant inventory unit cost (Shopify), when available.
  unitCost                      Decimal?                @map("unit_cost") @db.Decimal(14, 2)
  /// Shopify Location GID from FulfillmentOrder.assignedLocation — populated during order sync.
  shopifyLocationGid            String?                 @map("shopify_location_gid")
  /// For custom orders only: the PO line item this line was created from (hub-only, no FK constraint).
  sourcePurchaseOrderLineItemId String?                 @map("source_purchase_order_line_item_id")
  createdAt                     DateTime                @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                     DateTime                @updatedAt @map("updated_at") @db.Timestamptz
  purchaseOrderLineItems        PurchaseOrderLineItem[]
  fulfillmentLineItems          FulfillmentLineItem[]

  @@index([orderId])
  @@index([sourcePurchaseOrderLineItemId])
  @@index([sku])
  @@index([vendor])
  @@map("shopify_order_line_items")
  @@schema("order")
}

// --- Suppliers ---

model SupplierGroup {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  sortOrder Int        @default(0) @map("sort_order")
  suppliers Supplier[]
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  @@map("supplier_groups")
  @@schema("order")
}

model Supplier {
  id                   String                 @id @default(cuid())
  /// Shopify product vendor name (matched during import or manual link).
  shopifyVendorName    String?                @unique @map("shopify_vendor_name")
  company              String
  /// Short code in default PO numbers; if null, `company` is used (never supplier group name).
  officePoSupplierCode String?                @map("office_po_supplier_code")
  groupId              String?                @map("group_id")
  group                SupplierGroup?         @relation(fields: [groupId], references: [id])
  contactName          String?                @map("contact_name")
  /// One or more supplier contact emails (ordering / comm).
  contactEmails        String[]               @default([]) @map("contact_emails")
  contactPhone         String?                @map("contact_phone")
  /// Preferred communication channel (email, chat, sms).
  preferredCommMode    String?                @map("preferred_comm_mode")
  isFavorite           Boolean                @default(false) @map("is_favorite")
  /// External ordering URL (e.g. supplier's website for placing orders).
  link                 String?
  notes                String?                @db.Text
  purchaseOrders       PurchaseOrder[]
  vendorMappings       ShopifyVendorMapping[]
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt            DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  /// email | order_link | direct_instruction (extensible string).
  orderChannelType    String @default("email") @map("order_channel_type")
  /// Mode-specific JSON (contact, URLs, instructions).
  orderChannelPayload Json?  @map("order_channel_payload")
  /// Default PO expected delivery: ISO weekdays 1–7 (Mon–Sun), rule — see `supplier-delivery-schedule` zod.
  deliverySchedule    Json?  @map("delivery_schedule")

  customerDeliverySchedules SupplierCustomerDeliverySchedule[]

  @@index([groupId])
  @@map("suppliers")
  @@schema("order")
}

/// Per-customer override of a supplier's default `deliverySchedule`. When a customer
/// orders from this supplier, this schedule (same `supplier-delivery-schedule` zod shape)
/// replaces the supplier default for the PO expected-date computation in the inbox.
model SupplierCustomerDeliverySchedule {
  id         String          @id @default(cuid())
  supplierId String          @map("supplier_id")
  supplier   Supplier        @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  customerId String          @map("customer_id")
  customer   ShopifyCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// ISO weekdays 1–7 (Mon–Sun) + rule — see `supplier-delivery-schedule` zod.
  schedule   Json
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([supplierId, customerId])
  @@index([customerId])
  @@map("supplier_customer_delivery_schedules")
  @@schema("order")
}

/// A reusable, named delivery-schedule preset (e.g. "BH Shipping"). Holds the default
/// weekly partition windows that suppliers reference via `delivery_schedule.rule.presetId`.
/// Edit the preset once to update every supplier using it.
model DeliverySchedulePreset {
  id        String   @id @default(cuid())
  name      String   @unique
  /// IsoWeekWindow[] — the preset's default partition windows (see `supplier-delivery-schedule` zod).
  windows   Json
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  customerExceptions DeliverySchedulePresetCustomerException[]

  @@map("delivery_schedule_presets")
  @@schema("order")
}

/// Per-customer exception windows for a preset. When a supplier using preset P ships to
/// this customer, these windows replace the preset's default windows.
model DeliverySchedulePresetCustomerException {
  id         String                 @id @default(cuid())
  presetId   String                 @map("preset_id")
  preset     DeliverySchedulePreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  customerId String                 @map("customer_id")
  customer   ShopifyCustomer        @relation(fields: [customerId], references: [id], onDelete: Cascade)
  /// IsoWeekWindow[] — exception partition windows for this (preset, customer).
  windows    Json
  createdAt  DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([presetId, customerId])
  @@index([customerId])
  @@map("delivery_schedule_preset_customer_exceptions")
  @@schema("order")
}

/// Maps (Shopify vendor name, optional Shopify Location GID) → Supplier.
/// Multiple (vendorName, locationGid) pairs can point to the same Supplier.
/// When shopifyLocationGid is set, this mapping takes priority over the null-location fallback.
model ShopifyVendorMapping {
  id                  String   @id @default(cuid())
  vendorName          String   @map("vendor_name")
  /// Shopify Location GID (e.g. "gid://shopify/Location/123"). Null = default fallback for all locations.
  shopifyLocationGid  String?  @map("shopify_location_gid")
  /// Cached Shopify location name for display (populated at mapping creation time).
  shopifyLocationName String?  @map("shopify_location_name")
  supplierId          String   @map("supplier_id")
  supplier            Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@unique([vendorName, shopifyLocationGid])
  @@index([supplierId])
  @@map("shopify_vendor_mappings")
  @@schema("order")
}

/// Default PO line / PDF note per Shopify catalog variant (Admin `ProductVariant` GID).
model ShopifyVariantOfficeNote {
  id                String   @id @default(cuid())
  shopifyVariantGid String   @unique @map("shopify_variant_gid")
  note              String   @db.Text
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("shopify_variant_office_notes")
  @@schema("order")
}

// --- Purchase Orders ---

model PurchaseOrder {
  id                       String                    @id @default(cuid())
  /// Shopify app PO id from export `ID` column (stable key for idempotent import).
  legacyExternalId         Int?                      @unique @map("legacy_external_id")
  poNumber                 String                    @unique @map("po_number")
  /// customer = driven by Shopify orders, stock = office stocking without customer orders.
  poType                   String                    @default("customer") @map("po_type")
  /// pending | unfulfilled | partially_fulfilled | fulfilled | completed
  status                   String                    @default("unfulfilled")
  currency                 String
  isAuto                   Boolean                   @default(false) @map("is_auto")
  displayTaxColumn         Boolean                   @default(false) @map("display_tax_column")
  /// PO note — office UI, printed PO PDF, outbound PO email attachment.
  comment                  String?                   @db.Text
  authorizedBy             String?                   @map("authorized_by")
  unitsOrdered             Int?                      @map("units_ordered")
  dateCreated              DateTime?                 @map("date_created") @db.Date
  expectedDate             DateTime?                 @map("expected_date") @db.Date
  subtotalPrice            Decimal?                  @map("subtotal_price") @db.Decimal(14, 2)
  discount                 Decimal?                  @map("discount") @db.Decimal(14, 2)
  discountReason           String?                   @map("discount_reason") @db.Text
  shippingHandlingPrice    Decimal?                  @map("shipping_handling_price") @db.Decimal(14, 2)
  totalTaxPrice            Decimal?                  @map("total_tax_price") @db.Decimal(14, 2)
  totalPrice               Decimal?                  @map("total_price") @db.Decimal(14, 2)
  sourceCreatedAt          DateTime?                 @map("source_created_at") @db.Timestamptz
  sourceUpdatedAt          DateTime?                 @map("source_updated_at") @db.Timestamptz
  /// When all items were received from supplier.
  receivedAt               DateTime?                 @map("received_at") @db.Timestamptz
  /// When all line item qty+price were locked in (ready for invoicing).
  finalizedAt              DateTime?                 @map("finalized_at") @db.Timestamptz
  completedAt              DateTime?                 @map("completed_at") @db.Timestamptz
  archivedAt               DateTime?                 @map("archived_at") @db.Timestamptz
  emailSentAt              DateTime?                 @map("email_sent_at") @db.Timestamptz
  emailTrackingToken       String?                   @unique @map("email_tracking_token")
  emailOpenedAt            DateTime?                 @map("email_opened_at") @db.Timestamptz
  emailReplyReceivedAt     DateTime?                 @map("email_reply_received_at") @db.Timestamptz
  /// Office chose not to send supplier email; suppresses outstanding-email alerts until cleared or email is sent.
  emailDeliveryWaivedAt    DateTime?                 @map("email_delivery_waived_at") @db.Timestamptz
  /// Shipping address for this PO (JSON: address1, address2, city, province, postalCode, country).
  shippingAddress          Json?                     @map("shipping_address")
  /// Billing address for this PO (JSON, same shape as shipping).
  billingAddress           Json?                     @map("billing_address")
  billingSameAsShipping    Boolean                   @default(true) @map("billing_same_as_shipping")
  /// Optional link to `public.delivery_location_presets` when ship-to was chosen from a preset.
  deliveryLocationPresetId String?                   @map("delivery_location_preset_id")
  deliveryLocationPreset   DeliveryLocationPreset?   @relation(fields: [deliveryLocationPresetId], references: [id], onDelete: SetNull)
  /// Hub user who created this PO (`POST /api/purchase-orders`). Null for legacy CSV import rows.
  createdById              String?                   @map("created_by_id")
  createdBy                User?                     @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  supplierId               String?                   @map("supplier_id")
  supplier                 Supplier?                 @relation(fields: [supplierId], references: [id])
  shopifyOrders            ShopifyOrder[]
  lineItems                PurchaseOrderLineItem[]
  emailDeliveries          PoEmailDelivery[]
  refundReplacementRecords RefundReplacementRecord[]
  createdAt                DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([poType])
  @@index([status])
  @@index([supplierId])
  @@index([createdById])
  @@index([archivedAt])
  @@index([expectedDate])
  @@map("purchase_orders")
  @@schema("order")
}

model PurchaseOrderLineItem {
  id                      String                @id @default(cuid())
  purchaseOrderId         String                @map("purchase_order_id")
  legacyLineExternalId    Int?                  @map("legacy_line_external_id")
  sequence                Int                   @map("sequence")
  quantity                Int
  quantityReceived        Int                   @default(0) @map("quantity_received")
  supplierRef             String?               @map("supplier_ref") @db.Text
  taxPercent              Decimal?              @map("tax_percent") @db.Decimal(9, 4)
  sku                     String?
  variantTitle            String?               @map("variant_title")
  productTitle            String?               @map("product_title") @db.Text
  shopifyInventoryItemGid String?               @map("shopify_inventory_item_gid")
  shopifyVariantGid       String?               @map("shopify_variant_gid")
  shopifyProductGid       String?               @map("shopify_product_gid")
  isCustom                Boolean               @default(false) @map("is_custom")
  /// Expected supplier price per unit (from PO creation).
  itemPrice               Decimal?              @map("item_price") @db.Decimal(14, 2)
  lineSubtotalPrice       Decimal?              @map("line_subtotal_price") @db.Decimal(14, 2)
  lineTotalTaxPrice       Decimal?              @map("line_total_tax_price") @db.Decimal(14, 2)
  productProperties       String?               @map("product_properties") @db.Text
  /// Shown on PO PDF (right column). Defaults from `ShopifyVariantOfficeNote` at PO create; editable per PO line.
  note                    String?               @db.Text
  shopifyOrderLineItemId  String?               @map("shopify_order_line_item_id")
  shopifyOrderLineItem    ShopifyOrderLineItem? @relation(fields: [shopifyOrderLineItemId], references: [id])
  purchaseOrder           PurchaseOrder         @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  fulfillmentLineItems    FulfillmentLineItem[]

  @@unique([purchaseOrderId, sequence])
  @@index([purchaseOrderId, legacyLineExternalId])
  @@index([shopifyOrderLineItemId])
  @@map("purchase_order_line_items")
  @@schema("order")
}

/// Singleton (`id = "default"`): PO supplier outbound email — edited under Office → Contact Settings.
model OfficePoEmailSettings {
  id                    String   @id @default("default")
  senderName            String   @map("sender_name")
  ccEmail               String?  @map("cc_email") @db.Text
  /// Supports {{poNumber}}
  subjectTemplate       String   @map("subject_template") @db.Text
  /// Supports {{supplierName}}, {{poNumber}}. Optional legacy {{replyEmail}} → order@cmarket.ca.
  bodyIntroTemplate     String   @map("body_intro_template") @db.Text
  bodySignatureTemplate String   @map("body_signature_template") @db.Text
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("office_po_email_settings")
  @@schema("order")
}

model PoEmailDelivery {
  id              String        @id @default(cuid())
  purchaseOrderId String        @map("purchase_order_id")
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  recipientEmail  String        @map("recipient_email")
  recipientName   String?       @map("recipient_name")
  trackingToken   String        @unique @map("tracking_token")
  sentAt          DateTime      @map("sent_at") @db.Timestamptz
  openedAt        DateTime?     @map("opened_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  @@index([purchaseOrderId])
  @@map("po_email_deliveries")
  @@schema("order")
}

// --- Fulfillments (delivery phase, aligned with Shopify Fulfillment API) ---

/// A delivery event — one shipment or driver trip. Mirrors Shopify `Fulfillment`.
/// Multiple fulfillments can exist per order when items ship separately or from
/// different locations. Connects PO line items to a customer destination.
model Fulfillment {
  id              String                @id @default(cuid())
  /// Shopify Fulfillment GID (null for internal-only fulfillments like stock transfers).
  shopifyGid      String?               @unique @map("shopify_gid")
  /// supplier_direct | driver_pickup | driver_delivery | to_stock
  method          String
  /// Aligned with Shopify FulfillmentStatus: PENDING | OPEN | SUCCESS | CANCELLED | FAILURE
  status          String                @default("PENDING")
  /// Aligned with Shopify FulfillmentDisplayStatus for UI display.
  displayStatus   String?               @map("display_status")
  customerId      String?               @map("customer_id")
  customer        ShopifyCustomer?      @relation(fields: [customerId], references: [id])
  /// Reference to the Shopify order being fulfilled (for Shopify-linked fulfillments).
  shopifyOrderId  String?               @map("shopify_order_id")
  shopifyOrder    ShopifyOrder?         @relation(fields: [shopifyOrderId], references: [id])
  driverId        String?               @map("driver_id")
  trackingCompany String?               @map("tracking_company")
  trackingNumber  String?               @map("tracking_number")
  trackingUrl     String?               @map("tracking_url")
  originAddress   Json?                 @map("origin_address")
  scheduledAt     DateTime?             @map("scheduled_at") @db.Timestamptz
  inTransitAt     DateTime?             @map("in_transit_at") @db.Timestamptz
  deliveredAt     DateTime?             @map("delivered_at") @db.Timestamptz
  notes           String?               @db.Text
  lineItems       FulfillmentLineItem[]
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz

  @@index([customerId])
  @@index([shopifyOrderId])
  @@index([status])
  @@index([method])
  @@map("fulfillments")
  @@schema("order")
}

/// Per-item allocation within a fulfillment. Mirrors Shopify `FulfillmentLineItem`.
/// Links a PO line item to a specific delivery + customer with finalized qty/price.
/// This is the source of truth for invoicing: customer X got Y units at Z price from supplier W.
model FulfillmentLineItem {
  id                      String                 @id @default(cuid())
  fulfillmentId           String                 @map("fulfillment_id")
  fulfillment             Fulfillment            @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  purchaseOrderLineItemId String?                @map("purchase_order_line_item_id")
  purchaseOrderLineItem   PurchaseOrderLineItem? @relation(fields: [purchaseOrderLineItemId], references: [id])
  shopifyOrderLineItemId  String?                @map("shopify_order_line_item_id")
  shopifyOrderLineItem    ShopifyOrderLineItem?  @relation(fields: [shopifyOrderLineItemId], references: [id])
  /// Quantity allocated to this customer in this delivery.
  quantity                Int
  /// Supplier's actual price per unit (may differ from PO expected price).
  unitPrice               Decimal?               @map("unit_price") @db.Decimal(14, 2)
  /// Optional markup for external customers (null = pass-through at cost).
  marginPercent           Decimal?               @map("margin_percent") @db.Decimal(5, 2)
  /// When qty + price were locked in for invoicing.
  finalizedAt             DateTime?              @map("finalized_at") @db.Timestamptz
  createdAt               DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  @@index([fulfillmentId])
  @@index([purchaseOrderLineItemId])
  @@index([shopifyOrderLineItemId])
  @@map("fulfillment_line_items")
  @@schema("order")
}

/// Tracks refunds (Shopify orderEdit qty=0) and replacements (custom order) per PO line item.
/// type: 'refund' | 'replacement'
/// reasonCategory: 'supply_shortage' | 'item_damage' | 'human_error'
/// reasonSubcategory: 'out_of_stock' | 'payment_not_cleared' | 'unknown_damage' | 'poor_packaging' | 'office' | 'supply' | 'delivery'
model RefundReplacementRecord {
  id                String  @id @default(cuid())
  /// 'refund' | 'replacement'
  type              String
  /// 'supply_shortage' | 'item_damage' | 'human_error'
  reasonCategory    String  @map("reason_category")
  /// subcategory within reasonCategory
  reasonSubcategory String  @map("reason_subcategory")
  reasonNotes       String? @map("reason_notes") @db.Text

  purchaseOrderId         String        @map("purchase_order_id")
  purchaseOrder           PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  purchaseOrderLineItemId String?       @map("purchase_order_line_item_id")
  shopifyOrderId          String?       @map("shopify_order_id")
  shopifyLineItemGid      String?       @map("shopify_line_item_gid")
  /// For type='replacement': the ShopifyOrder.id of the created replacement order.
  replacementOrderId      String?       @map("replacement_order_id")

  productTitle String   @map("product_title") @db.Text
  variantTitle String?  @map("variant_title")
  sku          String?
  quantity     Int
  unitPrice    Decimal? @map("unit_price") @db.Decimal(14, 2)

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("RefundReplacementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([purchaseOrderId])
  @@index([type])
  @@index([reasonCategory])
  @@index([createdAt])
  @@index([replacementOrderId])
  @@map("refund_replacement_records")
  @@schema("order")
}

model RefundReasonOptions {
  id        String   @id @default(cuid())
  /// JSON array of ReasonCategory — managed via /api/order/reason-options
  data      Json
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("refund_reason_options")
  @@schema("order")
}

// ===============================
// LABOR (part-time shift scheduler — /labor module)
// All tables are row-scoped by location_id and guarded application-side
// (no DB RLS in this stack); see app/api/labor/* route handlers.
// ===============================

/// Per-location module settings (one row per location). Drives the engine.
model LaborSettings {
  locationId  String   @id @map("location_id")
  /// Labor budget as a fraction of revenue forecast (default 0.25).
  budgetPct   Decimal  @default(0.25) @map("budget_pct") @db.Decimal(5, 4)
  /// Fixed PT wage per hour.
  wage        Decimal  @map("wage") @db.Decimal(10, 2)
  minCov      Int      @default(1) @map("min_cov")
  maxCov      Int      @default(6) @map("max_cov")
  minShiftHrs Decimal  @default(3) @map("min_shift_hrs") @db.Decimal(4, 2)
  maxShiftHrs Decimal  @default(6) @map("max_shift_hrs") @db.Decimal(4, 2)
  increment   Decimal  @default(1.0) @map("increment") @db.Decimal(3, 2)
  /// First operating hour bucket (inclusive, 0-23).
  openHour    Int      @map("open_hour")
  /// Last operating hour bucket (inclusive, 0-23). 5AM-10PM → open=5, close=22.
  closeHour   Int      @map("close_hour")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@map("labor_settings")
  @@schema("labor")
}

/// Clover hourly net-sales rollup (store-local Vancouver hour), populated by the pipeline.
model CloverSalesHourly {
  locationId   String   @map("location_id")
  /// Store-local calendar date (YYYY-MM-DD).
  businessDate String   @map("business_date")
  /// Store-local hour 0-23.
  hour         Int      @map("hour")
  netSales     Decimal  @map("net_sales") @db.Decimal(14, 2)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, businessDate, hour])
  @@index([locationId, businessDate])
  @@map("clover_sales_hourly")
  @@schema("labor")
}

/// Nightly trimmed-mean heatmap cache. dow: 0=Sun..6=Sat (matches zonedWeekdaySun0).
model SalesHeatmapCache {
  locationId  String   @map("location_id")
  dow         Int      @map("dow")
  hour        Int      @map("hour")
  avgNetSales Decimal  @map("avg_net_sales") @db.Decimal(14, 2)
  sampleN     Int      @map("sample_n")
  computedAt  DateTime @map("computed_at") @db.Timestamptz
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, dow, hour])
  @@map("sales_heatmap_cache")
  @@schema("labor")
}

/// Dates the manager excludes from the trailing heatmap sample (holidays, closures, events).
model SalesSampleExclusion {
  id           String   @id @default(cuid())
  locationId   String   @map("location_id")
  businessDate String   @map("business_date")
  reason       String?  @map("reason")
  createdById  String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, businessDate])
  @@map("sales_sample_exclusions")
  @@schema("labor")
}

/// Monthly revenue forecast (office role writes; manager/admin read).
/// Distributed to days by weekday sales weight in the budget cascade.
model RevenueForecast {
  locationId  String   @map("location_id")
  yearMonth   String   @map("year_month")
  amount      Decimal  @map("amount") @db.Decimal(14, 2)
  createdById String?  @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, yearMonth])
  @@map("revenue_forecasts")
  @@schema("labor")
}

/// Monthly fixed payroll (manager role writes; office/admin read).
/// Spread evenly across the month's days in the budget cascade.
model FixedPayroll {
  locationId  String   @map("location_id")
  yearMonth   String   @map("year_month")
  amount      Decimal  @map("amount") @db.Decimal(14, 2)
  createdById String?  @map("created_by")
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([locationId, yearMonth])
  @@map("fixed_payroll")
  @@schema("labor")
}

/// A generated schedule plan for one location + date.
model LaborPlan {
  id            String              @id @default(cuid())
  locationId    String              @map("location_id")
  date          String              @map("date")
  laborBudget   Decimal             @map("labor_budget") @db.Decimal(14, 2)
  fixedPayroll  Decimal             @map("fixed_payroll") @db.Decimal(14, 2)
  ptLaborFee    Decimal             @map("pt_labor_fee") @db.Decimal(14, 2)
  wageUsed      Decimal             @map("wage_used") @db.Decimal(10, 2)
  affordableHrs Decimal             @map("affordable_hrs") @db.Decimal(8, 2)
  scheduledHrs  Decimal             @map("scheduled_hrs") @db.Decimal(8, 2)
  scheduledCost Decimal             @map("scheduled_cost") @db.Decimal(14, 2)
  /// DRAFT | OVER_BUDGET | PUBLISHED
  status        String              @map("status")
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  location      Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  shifts        LaborPlanShift[]
  coverage      LaborPlanCoverage[]

  @@index([locationId, date])
  @@map("labor_plans")
  @@schema("labor")
}

model LaborPlanShift {
  id         String    @id @default(cuid())
  planId     String    @map("plan_id")
  shiftIndex Int       @map("shift_index")
  startHour  Int       @map("start_hour")
  endHour    Int       @map("end_hour")
  /// Nullable; reserved for v2 role-aware columns. Left null in the MVP.
  role       String?   @map("role")
  plan       LaborPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, shiftIndex])
  @@map("labor_plan_shifts")
  @@schema("labor")
}

model LaborPlanCoverage {
  id              String    @id @default(cuid())
  planId          String    @map("plan_id")
  hour            Int       @map("hour")
  targetHeadcount Decimal   @map("target_headcount") @db.Decimal(5, 2)
  salesWeight     Decimal   @map("sales_weight") @db.Decimal(8, 6)
  salesAvg        Decimal   @map("sales_avg") @db.Decimal(14, 2)
  plan            LaborPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, hour])
  @@map("labor_plan_coverage")
  @@schema("labor")
}
